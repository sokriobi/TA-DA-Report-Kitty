{
  "version": 2,
  "functions": {
    "proxy.js": {
      "runtime": "@vercel/node"
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/public/login.html"
    },
    {
      "source": "/api/(.*)",
      "destination": "/proxy.js"
    },
    {
      "source": "/(.*)",
      "destination": "/public/$1"
    }
  ]
}
